# ═══════════════════════════════════════════════════════════
# Polymarket Crypto Bot v2 — Environment Variables
# ═══════════════════════════════════════════════════════════

# ─── Polymarket CLOB API (only needed for LIVE trading) ───
# Get API keys: https://docs.polymarket.com
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_FUNDER=

# ─── Bot Config (can also be set via CLI args) ───────────
BOT_BANKROLL=100
BOT_MAX_TRADE=5
BOT_MIN_EDGE=8
BOT_DRY_RUN=true

# ─── Sports Bot ───────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=
POLYMARKET_SIG_TYPE=2
ODDS_API_KEY=                  # the-odds-api.com (free tier: 500 req/month)
SPORTS_DRY_RUN=true

# ─── Telegram Bot ────────────────────────────────────────
TG_BOT_TOKEN=                  # @BotFather on Telegram
TG_CHAT_ID=                    # Your Telegram chat/user ID

# ─── 4-Agent Pipeline ────────────────────────────────────
ANTHROPIC_API_KEY=             # console.anthropic.com
GEMINI_API_KEY=                # aistudio.google.com
GROK_API_KEY=                  # console.x.ai
TAVILY_API_KEY=                # app.tavily.com (free tier available, optional)
                               # If not set, Max falls back to DuckDuckGo
